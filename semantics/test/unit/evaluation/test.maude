mod TEST--EVALUATION is

  pr TEST-BASE .

  op test--evaluation : -> TestResults .
  eq test--evaluation =
begin tests

  assert "numberOfCommandsOnExecutionWithId return 0 if there are no commands on execution" from
    testExpression(
      eval(
        mtenvironment,
        none,
        numberOfCommandsOnExecutionWithId('C)
      )
    )
  reaches
    anExpression(
      const(val(0))
    )
  end

  assert "numberOfCommandsOnExecutionWithId return the number of commands on execution with that Id as prefix" from
    testExpression(
      eval(
        mtenvironment,
        < 'C      : command-on-execution | none >
        < 'C      : command              | none >
        < 'C . 'B : list                 | none >
        < 'C . 'A : command-on-execution | none >
        < 'B . 'C : command-on-execution | none >
        ,
        numberOfCommandsOnExecutionWithId('C)
      )
    )
  reaches
    anExpression(
      const(val(2))
    )
  end

    assert "bEval over Config 1" from
      aBool(
        bEval(const(val(true)), [ nodes : none ] [ environment : mtenvironment ])
      )
    reaches
      aBool(
        true
      )
    end

    assert "bEval over Config" from
      aBool(
        bEval(const(val(false)), [ nodes : none ] [ environment : mtenvironment ])
      )
    reaches
      aBool(
        false
      )
    end

    assert "eval of arrayVar" from
      anExpression(
        eval(
            mtenvironment,
            [ < 'src . 'array8 : memory |
                    initVal: array(val(5.0) # val(6.0)),
                    actVal: array(val(5.0) # val(6.0)),
                    prevVal: array(val(5.0) # val(6.0)) > ],
            arrayVar('src . 'array8)
        )
      )
    reaches
      anExpression(
        const(array(val(5.0) # val(6.0)))
      )
    end

end tests
.

endm