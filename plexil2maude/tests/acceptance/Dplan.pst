// Nominal script for Dplan.ple

initial-state {
  state time () = 0 : real;
}

script {

  // Macro-steps for initial variable assignments, pprint calls, and
  // perhaps other execution steps.  Note that it is difficult to
  // identify each macro-step in a plan, and the correct number of
  // initial 'delays' is gotten by experimentation.
  delay;
  delay;
  delay;
  delay;
  delay;
  delay;

  // Initial drag
  command-success low_drag();

  // First switch
  state time () = 1773659940.0 : real;
  delay;
  delay;
  command-success high_drag();

  // Second switch
  state time () = 1773663003.0 : real;
  delay;
  delay;
  command-success low_drag();

  // Third switch
  state time () = 1773665832.0 : real;
  delay;
  delay;
  command-success high_drag();

  // Fourth switch
  state time () = 1773666832.0 : real;
  delay;
  delay;
  command-success low_drag();
}
